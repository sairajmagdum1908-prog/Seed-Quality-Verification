{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth.ts"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users.ts"
    },
    {
      "src": "/api/seeds/(.*)",
      "dest": "/api/seeds.ts"
    },
    {
      "src": "/api/transactions/(.*)",
      "dest": "/api/transactions.ts"
    },
    {
      "src": "/api/reports/(.*)",
      "dest": "/api/reports.ts"
    },
    {
      "src": "/api/ai/(.*)",
      "dest": "/api/ai.ts"
    },
    {
      "src": "/api/stats",
      "dest": "/api/stats.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
